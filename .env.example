# =============================================================================
# Travel Planner — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.
# All variables without a default are REQUIRED.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# The public URL of your app (used for OAuth callbacks, email links, PWA manifest)
# Development: http://localhost:3000
# Production:  https://yourapp.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment — must be "production" in Docker
NODE_ENV=development
# Show Next.js dev toolbar in the browser (true = show, false = hide)
NEXT_DEV_INDICATORS=false

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgresql://{user}:{password}@{host}:{port}/{database}
# Development: postgresql://postgres:password@localhost:5432/travel_planner
# Docker:      postgresql://postgres:password@host.docker.internal:5432/travel_planner
DATABASE_URL=postgresql://postgres:password@localhost:5432/travel_planner

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------

# Secret used to sign session tokens — generate with: openssl rand -base64 32
# MUST be changed in production — never use the default
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# URL Better Auth uses to build callback URLs (same as NEXT_PUBLIC_APP_URL)
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth Providers (optional — remove sections you don't use)
# -----------------------------------------------------------------------------

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (important for iPhone users)
# Create credentials at: https://developer.apple.com/account/resources/identifiers
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/callback/apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------

# Where uploaded files are stored on disk (absolute path)
# The Nginx config must serve this directory as /uploads/
UPLOAD_DIR=/app/uploads

# Maximum upload file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# Allowed MIME types for uploads (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/heic,application/pdf

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS and Next.js dev server LAN access.
# Dev: leave empty to allow all origins, or specify IPs to restrict (e.g. your phone's IP).
# Production: MUST be set to your app's domain, otherwise all cross-origin requests are blocked.
# Example: https://yourapp.example.com,192.168.1.100
ALLOWED_ORIGINS=

# Rate limiting: max requests per IP per minute on /api routes (0 = disabled)
RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Email (optional — for password reset and invite emails)
# Omit to disable email features
# -----------------------------------------------------------------------------

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# SMTP server details (legacy)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourapp.example.com

# -----------------------------------------------------------------------------
# Mapbox
# -----------------------------------------------------------------------------

# Public token for map tiles and geocoding (safe to expose in browser)
# Create at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# -----------------------------------------------------------------------------
# Deployment (Docker / Production only)
# -----------------------------------------------------------------------------

# Internal port Next.js listens on inside Docker (default: 3000)
PORT=3000

# Hostname Next.js binds to inside Docker (0.0.0.0 = all interfaces)
HOSTNAME=0.0.0.0
